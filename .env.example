# ================================
# DATABASE
# ================================
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_secure_password

# ================================
# BACKEND  (backend/.env)
# ================================
DATABASE_URL=postgresql://appuser:changeme_secure_password@localhost:5432/appdb

# JWT — générer avec: openssl rand -base64 64
JWT_ACCESS_SECRET=change_me_very_long_random_secret_access
JWT_REFRESH_SECRET=change_me_very_long_random_secret_refresh

# URL du frontend (pour les emails)
FRONTEND_URL=http://localhost:3000

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Seed admin (optionnel)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin1234!

# ================================
# FRONTEND  (frontend/.env.local)
# ================================
# URL du backend (sans /api)
NEXT_PUBLIC_API_URL=http://localhost:4000
