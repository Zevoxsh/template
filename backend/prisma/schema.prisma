generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)
  banned        Boolean  @default(false)
  bannedReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  avatarUrl         String?
  avatarFlagged     Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorMethod   String?
  twoFactorSecret   String?
  backupCodes       String[]
  // Onboarding
  onboardingDone    Boolean  @default(false)
  // Notification preferences (JSON: { marketing, security, updates })
  notifPrefs        Json     @default("{\"security\":true,\"updates\":true,\"marketing\":false}")
  // Inactivity timeout override (null = use global setting)
  inactivityTimeout Int?
  tokens            Token[]
  oauthAccounts     OAuthAccount[]
  notifications     Notification[]
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  // Session metadata (for REFRESH tokens)
  userAgent String?
  ipAddress String?
  lastUsed  DateTime?
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH
  TWO_FACTOR_CHALLENGE
  TWO_FACTOR_EMAIL
}

model SiteSettings {
  id                       String   @id @default("singleton")
  siteName                 String   @default("My App")
  siteDescription          String   @default("Welcome to My App")
  registrationEnabled      Boolean  @default(true)
  requireEmailVerification Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  twoFactorPolicy          String   @default("OPTIONAL")
  twoFactorAllowedMethods  String[] @default(["totp", "email"])
  // Inactivity timeout in minutes (0 = disabled)
  inactivityTimeout        Int      @default(0)
  // Global announcement banner
  announcementEnabled      Boolean  @default(false)
  announcementText         String   @default("")
  announcementType         String   @default("info")
  // Email templates (JSON keyed by template name)
  emailTemplates           Json     @default("{}")
  updatedAt                DateTime @updatedAt
}

model OAuthProvider {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  enabled      Boolean  @default(false)
  clientId     String   @default("")
  clientSecret String   @default("")
  authUrl      String   @default("")
  tokenUrl     String   @default("")
  userInfoUrl  String   @default("")
  scope        String   @default("")
  iconUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LdapConfig {
  id           String   @id @default("singleton")
  enabled      Boolean  @default(false)
  host         String   @default("")
  port         Int      @default(389)
  bindDn       String   @default("")
  bindPassword String   @default("")
  searchBase   String   @default("")
  searchFilter String   @default("(uid={{username}})")
  useTls       Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model RolePermission {
  id          String   @id @default(cuid())
  role        Role
  permission  String
  createdAt   DateTime @default(now())

  @@unique([role, permission])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  targetName String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model RateLimitBlock {
  id          String   @id @default(cuid())
  ipAddress   String
  route       String
  attempts    Int      @default(1)
  blockedAt   DateTime @default(now())
  unblockedAt DateTime?

  @@unique([ipAddress, route])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
